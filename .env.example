# Налаштування проекту КІНО.UA
# Скопіюйте цей файл у .env.local та заповніть значення

# ==================================
# TMDB API (The Movie Database)
# ==================================
# Отримайте API ключ на: https://www.themoviedb.org/settings/api
NEXT_PUBLIC_TMDB_API_KEY=your_tmdb_api_key_here
NEXT_PUBLIC_TMDB_BASE_URL=https://api.themoviedb.org/3
NEXT_PUBLIC_TMDB_IMAGE_BASE_URL=https://image.tmdb.org/t/p

# ==================================
# VideoCDN / Ashdi API
# ==================================
# Для інтеграції відео плеєра
NEXT_PUBLIC_VIDEO_API_KEY=your_video_api_key_here
NEXT_PUBLIC_VIDEO_API_URL=https://videocdn.tv/api

# ==================================
# Supabase (PostgreSQL)
# ==================================
# База даних для зберігання користувачів та даних
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# ==================================
# Налаштування додатку
# ==================================
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_NAME=КІНО.UA
NODE_ENV=development

# ==================================
# Аналітика (опціонально)
# ==================================
# Google Analytics
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Vercel Analytics
NEXT_PUBLIC_VERCEL_ANALYTICS_ID=your_vercel_analytics_id

# ==================================
# Безпека
# ==================================
# Секретний ключ для JWT (згенеруйте випадковий)
JWT_SECRET=your_super_secret_jwt_key_here

# ==================================
# Email (опціонально)
# ==================================
# Для відправки повідомлень користувачам
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_email_password
